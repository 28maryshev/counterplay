<Window x:Class="Counterplay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Counterplay"
        Title="Counterplay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MouseLeftButtonDown="OnDrag"
        KeyDown="OnKeyDown">

  <Window.Resources>
    <!-- Основной текст — Geist (встроен в сборку), как на сайте. Запасной Segoe UI. -->
    <FontFamily x:Key="UiFont">/assets/fonts/#Geist, Segoe UI</FontFamily>
    <!-- Заголовки/имена — тоже Geist, чтобы весь интерфейс был единым шрифтом. -->
    <FontFamily x:Key="DisplayFont">/assets/fonts/#Geist, Segoe UI</FontFamily>
    <!-- Цифры позиции — тоже Geist (единый шрифт). -->
    <FontFamily x:Key="NumberFont">/assets/fonts/#Geist, Segoe UI</FontFamily>

    <!-- Выпадающий список ролей врага — в цветах кнопки-чипа (тёмный фон,
         рамка #557089, золотая подсветка выбранного/наведённого пункта). -->
    <Style x:Key="RoleMenuStyle" TargetType="ContextMenu">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ContextMenu">
            <Border Background="#101823" BorderBrush="#557089" BorderThickness="1"
                    CornerRadius="6" Padding="4" Margin="0,2,6,6">
              <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.6"/>
              </Border.Effect>
              <StackPanel IsItemsHost="True"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="RoleMenuItemStyle" TargetType="MenuItem">
      <Setter Property="Foreground" Value="#C9D2DC"/>
      <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="MenuItem">
            <Border x:Name="bd" CornerRadius="4" Padding="12,5" Background="Transparent">
              <ContentPresenter ContentSource="Header" RecognizesAccessKey="False"/>
            </Border>
            <ControlTemplate.Triggers>
              <!-- Наведение: лёгкий фон + золото, как ховер чипа -->
              <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#26FFFFFF"/>
                <Setter Property="Foreground" Value="#F5D77A"/>
              </Trigger>
              <!-- Текущий выбор — золотом -->
              <Trigger Property="IsChecked" Value="True">
                <Setter Property="Foreground" Value="#F5D77A"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Сине-красный «волновой» градиент (как на сайте): cyan → синий → красный.
         Используется для рамки окна и фоновых «дымок». -->
    <LinearGradientBrush x:Key="WaveBrush" StartPoint="0,0" EndPoint="1,0">
      <GradientStop Color="#36D6E7" Offset="0"/>
      <GradientStop Color="#3B82C4" Offset="0.5"/>
      <!-- красный приглушён прозрачностью, чтобы не «кричал» -->
      <GradientStop Color="#88F0685E" Offset="1"/>
    </LinearGradientBrush>

    <!-- Логотип-марка (как на сайте): тёмная плитка + РОВНОЕ ПРЕРЫВИСТОЕ кольцо.
         Чистые разрывы сверху/снизу делаем обрезкой половинок (как clip на сайте),
         а не смыканием дуг. Левая половина синяя, правая красная. -->
    <DrawingImage x:Key="BrandMark">
      <DrawingImage.Drawing>
        <DrawingGroup>
          <!-- Плитка -->
          <GeometryDrawing Brush="#0B1322">
            <GeometryDrawing.Geometry>
              <RectangleGeometry Rect="8,8,240,240" RadiusX="54" RadiusY="54"/>
            </GeometryDrawing.Geometry>
            <GeometryDrawing.Pen><Pen Thickness="2" Brush="#1E2A3A"/></GeometryDrawing.Pen>
          </GeometryDrawing>
          <!-- Синяя половина (обрезка слева, разрыв 120..136) -->
          <DrawingGroup>
            <DrawingGroup.ClipGeometry><RectangleGeometry Rect="0,0,120,256"/></DrawingGroup.ClipGeometry>
            <GeometryDrawing>
              <GeometryDrawing.Pen>
                <Pen Thickness="7">
                  <Pen.Brush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                      <GradientStop Color="#6FE6F2" Offset="0"/>
                      <GradientStop Color="#36D6E7" Offset="0.5"/>
                      <GradientStop Color="#2B6FD0" Offset="1"/>
                    </LinearGradientBrush>
                  </Pen.Brush>
                </Pen>
              </GeometryDrawing.Pen>
              <GeometryDrawing.Geometry><EllipseGeometry Center="128,128" RadiusX="90" RadiusY="90"/></GeometryDrawing.Geometry>
            </GeometryDrawing>
            <GeometryDrawing>
              <GeometryDrawing.Pen>
                <Pen Thickness="21">
                  <Pen.Brush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                      <GradientStop Color="#6FE6F2" Offset="0"/>
                      <GradientStop Color="#36D6E7" Offset="0.5"/>
                      <GradientStop Color="#2B6FD0" Offset="1"/>
                    </LinearGradientBrush>
                  </Pen.Brush>
                </Pen>
              </GeometryDrawing.Pen>
              <GeometryDrawing.Geometry><EllipseGeometry Center="128,128" RadiusX="64" RadiusY="64"/></GeometryDrawing.Geometry>
            </GeometryDrawing>
          </DrawingGroup>
          <!-- Красная половина (обрезка справа) -->
          <DrawingGroup>
            <DrawingGroup.ClipGeometry><RectangleGeometry Rect="136,0,120,256"/></DrawingGroup.ClipGeometry>
            <GeometryDrawing>
              <GeometryDrawing.Pen>
                <Pen Thickness="7">
                  <Pen.Brush>
                    <LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
                      <GradientStop Color="#FF8A66" Offset="0"/>
                      <GradientStop Color="#FF5A4D" Offset="0.5"/>
                      <GradientStop Color="#B8232B" Offset="1"/>
                    </LinearGradientBrush>
                  </Pen.Brush>
                </Pen>
              </GeometryDrawing.Pen>
              <GeometryDrawing.Geometry><EllipseGeometry Center="128,128" RadiusX="90" RadiusY="90"/></GeometryDrawing.Geometry>
            </GeometryDrawing>
            <GeometryDrawing>
              <GeometryDrawing.Pen>
                <Pen Thickness="21">
                  <Pen.Brush>
                    <LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
                      <GradientStop Color="#FF8A66" Offset="0"/>
                      <GradientStop Color="#FF5A4D" Offset="0.5"/>
                      <GradientStop Color="#B8232B" Offset="1"/>
                    </LinearGradientBrush>
                  </Pen.Brush>
                </Pen>
              </GeometryDrawing.Pen>
              <GeometryDrawing.Geometry><EllipseGeometry Center="128,128" RadiusX="64" RadiusY="64"/></GeometryDrawing.Geometry>
            </GeometryDrawing>
          </DrawingGroup>
        </DrawingGroup>
      </DrawingImage.Drawing>
    </DrawingImage>

    <!-- Карточка командной связки (комбо) — общая для союзников и врагов -->
    <!-- ── Тёмный ComboBox (селектор языка) ─────────────────────────── -->
    <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
      <Setter Property="Foreground" Value="#C9D2DC"/>
      <Setter Property="Padding" Value="9,5"/>
      <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBoxItem">
            <Border x:Name="bd" Background="Transparent" CornerRadius="3"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#1E2A3A"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="#36D6E7"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <ControlTemplate x:Key="DarkComboToggle" TargetType="ToggleButton">
      <Border x:Name="bd" Background="#142033" BorderBrush="#2A3A4F" BorderThickness="1"
              CornerRadius="5">
        <Path HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"
              Data="M0,0 L4,4 L8,0 Z" Fill="#9AA4B2"/>
      </Border>
      <ControlTemplate.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter TargetName="bd" Property="BorderBrush" Value="#36D6E7"/>
        </Trigger>
        <Trigger Property="IsChecked" Value="True">
          <Setter TargetName="bd" Property="BorderBrush" Value="#36D6E7"/>
        </Trigger>
      </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="DarkCombo" TargetType="ComboBox">
      <Setter Property="Foreground" Value="#E8E6DF"/>
      <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="SnapsToDevicePixels" Value="True"/>
      <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboItem}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <ToggleButton Template="{StaticResource DarkComboToggle}" Focusable="False"
                            ClickMode="Press"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
              <ContentPresenter IsHitTestVisible="False"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                Margin="10,0,24,0"
                                VerticalAlignment="Center" HorizontalAlignment="Left"/>
              <Popup Placement="Bottom" Focusable="False" AllowsTransparency="True"
                     PopupAnimation="Slide"
                     IsOpen="{TemplateBinding IsDropDownOpen}">
                <Border Background="#0F1622" BorderBrush="#2A3A4F" BorderThickness="1"
                        CornerRadius="5" Margin="0,3,0,0"
                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                  <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.6"/>
                  </Border.Effect>
                  <ScrollViewer MaxHeight="280">
                    <ItemsPresenter/>
                  </ScrollViewer>
                </Border>
              </Popup>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <DataTemplate x:Key="ComboTemplate">
      <Border Background="#22FFFFFF" CornerRadius="4" Margin="0,5,0,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <!-- Цветная метка связки = цвет её коннектор-линии -->
          <Border Grid.Column="0" Background="{Binding LineColor}" CornerRadius="4,0,0,4"/>
          <StackPanel Grid.Column="1" Margin="8,7,8,7">
          <TextBlock Text="{Binding Title}" Foreground="{Binding AccentColor}"
                     FontFamily="{StaticResource DisplayFont}" FontSize="12" FontWeight="Bold"
                     TextWrapping="Wrap"/>
          <ItemsControl ItemsSource="{Binding Icons}" Margin="0,6,0,0">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Width="30" Height="30" CornerRadius="15"
                        ClipToBounds="True" Margin="0,0,5,0">
                  <Image Source="{Binding}" Stretch="UniformToFill"/>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Text="{Binding Description}" Foreground="#9AB2C6"
                     FontFamily="{StaticResource UiFont}" FontSize="10.5"
                     TextWrapping="Wrap" Margin="0,6,0,0" LineHeight="15"/>
          <TextBlock Text="{Binding TipLabel}" Foreground="{Binding AccentColor}"
                     FontFamily="{StaticResource UiFont}" FontSize="9" FontWeight="Bold"
                     Margin="0,6,0,1"/>
          <TextBlock Text="{Binding Tip}" Foreground="#6A8AA0"
                     FontFamily="{StaticResource UiFont}" FontSize="10.5"
                     TextWrapping="Wrap" LineHeight="15"/>
          </StackPanel>
        </Grid>
      </Border>
    </DataTemplate>
  </Window.Resources>

  <Grid>

    <!-- ═══════════════ ОСНОВНОЙ КОНТЕНТ ═══════════════ -->
    <Border Background="#D8071223" BorderBrush="{StaticResource WaveBrush}" BorderThickness="1.4"
            CornerRadius="4" Margin="5">
      <Border.Effect>
        <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="3" Opacity="0.7"/>
      </Border.Effect>

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>  <!-- шапка       -->
          <RowDefinition Height="Auto"/>  <!-- статус      -->
          <RowDefinition Height="*"/>     <!-- контент     -->
          <RowDefinition Height="Auto"/>  <!-- дисклеймер  -->
        </Grid.RowDefinitions>

        <!-- ── Декоративный фон в стиле клиента (полупрозрачный) ──────── -->
        <Grid Grid.RowSpan="4" IsHitTestVisible="False" ClipToBounds="True">
          <!-- мягкая диагональная подсветка -->
          <Rectangle>
            <Rectangle.Fill>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1636D6E7" Offset="0"/>
                <GradientStop Color="#00071223" Offset="0.45"/>
                <GradientStop Color="#0CFF5A4D" Offset="1"/>
              </LinearGradientBrush>
            </Rectangle.Fill>
          </Rectangle>

          <!-- синее свечение сверху-слева (как левая половина логотипа) -->
          <Ellipse Width="560" Height="320" HorizontalAlignment="Left"
                   VerticalAlignment="Top" Margin="-140,-110,0,0">
            <Ellipse.Fill>
              <RadialGradientBrush>
                <GradientStop Color="#2636D6E7" Offset="0"/>
                <GradientStop Color="#0036D6E7" Offset="1"/>
              </RadialGradientBrush>
            </Ellipse.Fill>
          </Ellipse>
          <!-- красное свечение снизу-справа (как правая половина логотипа) -->
          <Ellipse Width="620" Height="360" HorizontalAlignment="Right"
                   VerticalAlignment="Bottom" Margin="0,0,-160,-120">
            <Ellipse.Fill>
              <RadialGradientBrush>
                <GradientStop Color="#10FF5A4D" Offset="0"/>
                <GradientStop Color="#00FF5A4D" Offset="1"/>
              </RadialGradientBrush>
            </Ellipse.Fill>
          </Ellipse>

          <!-- Потоки «ветра/дымки» — плавно дрейфуют -->
          <Canvas>
            <Canvas.Resources>
              <!-- общий стиль кривой -->
              <Style x:Key="Wisp" TargetType="Path">
                <Setter Property="Stroke" Value="{StaticResource WaveBrush}"/>
                <Setter Property="StrokeThickness" Value="1.6"/>
                <Setter Property="Opacity" Value="0.22"/>
                <Setter Property="StrokeStartLineCap" Value="Round"/>
                <Setter Property="StrokeEndLineCap" Value="Round"/>
              </Style>
            </Canvas.Resources>

            <Path Style="{StaticResource Wisp}"
                  Data="M -80,90 C 220,30 520,170 820,90 S 1320,20 1640,130"
                  RenderTransformOrigin="0.5,0.5">
              <Path.RenderTransform><TranslateTransform x:Name="W1"/></Path.RenderTransform>
              <Path.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetName="W1" Storyboard.TargetProperty="X"
                                       From="0" To="46" Duration="0:0:11"
                                       AutoReverse="True" RepeatBehavior="Forever"/>
                    </Storyboard>
                  </BeginStoryboard>
                </EventTrigger>
              </Path.Triggers>
            </Path>

            <Path Style="{StaticResource Wisp}" Opacity="0.07"
                  Data="M -80,260 C 260,200 560,330 880,250 S 1340,180 1660,300">
              <Path.RenderTransform><TranslateTransform x:Name="W2"/></Path.RenderTransform>
              <Path.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetName="W2" Storyboard.TargetProperty="X"
                                       From="0" To="-40" Duration="0:0:14"
                                       AutoReverse="True" RepeatBehavior="Forever"/>
                    </Storyboard>
                  </BeginStoryboard>
                </EventTrigger>
              </Path.Triggers>
            </Path>

            <Path Style="{StaticResource Wisp}" Opacity="0.06"
                  Data="M -80,440 C 240,380 540,510 860,430 S 1320,360 1660,470">
              <Path.RenderTransform><TranslateTransform x:Name="W3"/></Path.RenderTransform>
              <Path.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetName="W3" Storyboard.TargetProperty="X"
                                       From="0" To="36" Duration="0:0:17"
                                       AutoReverse="True" RepeatBehavior="Forever"/>
                    </Storyboard>
                  </BeginStoryboard>
                </EventTrigger>
              </Path.Triggers>
            </Path>
          </Canvas>
        </Grid>

        <!-- ── Шапка ─────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="12,10,10,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Image Source="{StaticResource BrandMark}" Width="22" Height="22"
                   Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock FontFamily="{StaticResource UiFont}" FontSize="13" FontWeight="Bold"
                       VerticalAlignment="Center">
              <Run Text="Counter" Foreground="#36D6E7"/><Run Text="Play" Foreground="#FF5A4D"/>
            </TextBlock>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal">
            <ComboBox x:Name="LangBox" Width="96" Height="26" Margin="0,0,8,0"
                      Style="{StaticResource DarkCombo}"
                      SelectedValuePath="Code"
                      SelectionChanged="OnLangChanged"
                      ToolTip="Язык / Language">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Native}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button x:Name="PinBtn" Content="📌" Click="OnPin"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#C89B3C" FontSize="14" Padding="6,0"
                    Cursor="Hand" ToolTip="{loc:T tip.pin}"/>
            <Button x:Name="ToggleBtn" Content="⊟" Click="OnToggle"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#C89B3C" FontSize="17" Padding="6,0"
                    Cursor="Hand" ToolTip="{loc:T tip.minimize}"/>
            <Button Content="✕" Click="OnClose"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#507090" FontSize="12" Padding="6,0"
                    Cursor="Hand"/>
          </StackPanel>
        </Grid>

        <!-- ── Статус + подсказка по порядку пика ────────────────────── -->
        <StackPanel Grid.Row="1" Margin="12,5,12,8">
          <TextBlock x:Name="StatusText" Text="{loc:T status.waitClient}"
                     FontFamily="{StaticResource UiFont}" FontSize="11"
                     Foreground="#5A7A90"/>
          <TextBlock x:Name="PickHint" Visibility="Collapsed"
                     FontFamily="{StaticResource UiFont}" FontSize="11" FontWeight="Bold"
                     Foreground="#E8B84B" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ══ ЭКРАН ОЖИДАНИЯ ════════════════════════════════════════ -->
        <StackPanel Grid.Row="2" x:Name="IdlePanel" Visibility="Collapsed"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Margin="24,18,24,28">

          <!-- ── Стадия загрузки/ожидания: точки + крупный статус + прогресс ── -->
          <StackPanel x:Name="LoadingInfo">
            <!-- Три точки, поочередно медленно мигающие -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18">
              <StackPanel.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                  <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                      <DoubleAnimation Storyboard.TargetName="Dot1" Storyboard.TargetProperty="Opacity"
                                       From="1.0" To="0.2" Duration="0:0:0.7" AutoReverse="True"
                                       BeginTime="0:0:0.0"/>
                      <DoubleAnimation Storyboard.TargetName="Dot2" Storyboard.TargetProperty="Opacity"
                                       From="1.0" To="0.2" Duration="0:0:0.7" AutoReverse="True"
                                       BeginTime="0:0:0.4"/>
                      <DoubleAnimation Storyboard.TargetName="Dot3" Storyboard.TargetProperty="Opacity"
                                       From="1.0" To="0.2" Duration="0:0:0.7" AutoReverse="True"
                                       BeginTime="0:0:0.8"/>
                    </Storyboard>
                  </BeginStoryboard>
                </EventTrigger>
              </StackPanel.Triggers>
              <Ellipse x:Name="Dot1" Width="12" Height="12" Fill="#C89B3C" Opacity="0.2" Margin="5,0"/>
              <Ellipse x:Name="Dot2" Width="12" Height="12" Fill="#C89B3C" Opacity="0.2" Margin="5,0"/>
              <Ellipse x:Name="Dot3" Width="12" Height="12" Fill="#C89B3C" Opacity="0.2" Margin="5,0"/>
            </StackPanel>

            <!-- Крупная подпись текущей стадии -->
            <TextBlock x:Name="IdleStatusText" Text="{loc:T status.waitClient}"
                       FontFamily="{StaticResource DisplayFont}" FontSize="20" FontWeight="Bold"
                       Foreground="#E8E0CC" TextAlignment="Center" TextWrapping="Wrap"
                       MaxWidth="300"/>

            <!-- Полоса прогресса загрузки (обновление/база) -->
            <Grid x:Name="DlBar" Width="260" Height="8" Margin="0,14,0,0"
                  Visibility="Collapsed" ClipToBounds="True">
              <Border Background="#1AFFFFFF" CornerRadius="4"/>
              <Border x:Name="DlBarFill" HorizontalAlignment="Left" Width="0"
                      Background="#C89B3C" CornerRadius="4"/>
              <!-- Скользящий блик: бар «живой» даже когда % замер на распаковке -->
              <Border x:Name="DlBarPulse" HorizontalAlignment="Left" Width="70"
                      CornerRadius="4" IsHitTestVisible="False">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#00FFFFFF" Offset="0"/>
                    <GradientStop Color="#66FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                  <TranslateTransform x:Name="DlBarPulseT" X="-70"/>
                </Border.RenderTransform>
              </Border>
            </Grid>
          </StackPanel>

          <!-- ── Готов: трекер сессии (ранг/LP/последние игры/винрейт) + советы ── -->
          <StackPanel x:Name="ReadyInfo" Visibility="Collapsed" MaxWidth="282">

            <!-- Эмблема ранга + ник с «крыльями» (в цвет ранга) и выбор очереди -->
            <Grid>
              <Grid.Resources>
                <!-- Крыло из трёх перьев — как на ранговых эмблемах -->
                <Geometry x:Key="WingGeometry">M18,0 C9,1 3,5 0,11 C3.5,9.5 6.5,9 9.5,9.3 C6.5,10.6 4,12.2 2,14.5 C5.5,13.6 8.5,13.2 11,13.8 C9,15 7.5,16.2 6.5,17.5 C11,16.8 14.5,14.6 16.4,10.8 C17.6,8 18,4.2 18,0 Z</Geometry>
              </Grid.Resources>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Image x:Name="RankEmblem" Grid.Column="0" Height="74" HorizontalAlignment="Left"
                     Margin="-6,0,0,-4" Stretch="Uniform" Visibility="Collapsed"
                     RenderOptions.BitmapScalingMode="HighQuality"/>
              <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right"
                          Margin="0,2,2,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                  <Path x:Name="WingLeft" Data="{StaticResource WingGeometry}"
                        Width="15" Height="13" Stretch="Uniform" Fill="#557089"
                        VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.9"/>
                  <TextBlock x:Name="NickText" Text=""
                             FontFamily="{StaticResource DisplayFont}" FontSize="14" FontWeight="Bold"
                             Foreground="#E6EDF3" TextTrimming="CharacterEllipsis" MaxWidth="140"
                             VerticalAlignment="Center"/>
                  <Path x:Name="WingRight" Data="{StaticResource WingGeometry}"
                        Width="15" Height="13" Stretch="Uniform" Fill="#557089"
                        VerticalAlignment="Center" Margin="6,0,0,0" Opacity="0.9"
                        RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform><ScaleTransform ScaleX="-1"/></Path.RenderTransform>
                  </Path>
                </StackPanel>
                <!-- Очередь: кнопка-чип с выпадающим списком (стата по очередям) -->
                <Border x:Name="QueueChip" HorizontalAlignment="Right" Margin="0,6,0,0"
                        CornerRadius="4" BorderBrush="#557089" BorderThickness="1"
                        Background="#1AFFFFFF" Padding="9,2,9,3" Cursor="Hand"
                        MouseLeftButtonDown="QueueChip_Click">
                  <TextBlock x:Name="QueueText" Text=""
                             FontFamily="{StaticResource DisplayFont}" FontSize="11" FontWeight="Bold"
                             Foreground="#C9D2DC"/>
                </Border>
              </StackPanel>
            </Grid>

            <!-- Ранг · LP · полоса прогресса до след. ранга -->
            <Grid Margin="0,2,0,4" Width="258" HorizontalAlignment="Left">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="RankText" Grid.Column="0" Text="—"
                         FontFamily="{StaticResource DisplayFont}" FontSize="19" FontWeight="Bold"
                         Foreground="#E6EDF3" VerticalAlignment="Bottom"/>
              <TextBlock x:Name="RankLpText" Grid.Column="1" Text=""
                         FontFamily="{StaticResource UiFont}" FontSize="13" FontWeight="Bold"
                         Foreground="#9FB3C8" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
            </Grid>
            <!-- Полоса LP -->
            <Border Width="258" Height="7" CornerRadius="4" HorizontalAlignment="Left"
                    Background="#22FFFFFF">
              <Border x:Name="RankProgressFill" Width="0" Height="7" CornerRadius="4"
                      HorizontalAlignment="Left">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#2E7DD1" Offset="0"/>
                    <GradientStop Color="#36D6E7" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
              </Border>
            </Border>

            <!-- Последние 5 игр: иконки во всю ширину бара + LP за игру -->
            <Grid x:Name="Last5Panel" Width="258" HorizontalAlignment="Left" Margin="0,15,0,0"/>

            <!-- Подсказка: статистика наполняется по мере сыгранных игр -->
            <TextBlock x:Name="SessionHint" Visibility="Collapsed"
                       FontFamily="{StaticResource UiFont}" FontSize="11"
                       Foreground="#8AA0B2" TextWrapping="Wrap" LineHeight="15"
                       Margin="0,10,0,0"/>

            <!-- Винрейт слева (W–L мелко, % крупно с цветом) + график справа -->
            <Grid Margin="0,16,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock x:Name="SeasonWlText" FontFamily="{StaticResource UiFont}"
                           FontSize="12" FontWeight="Bold" Foreground="#9FB3C8"/>
                <TextBlock x:Name="WinrateBig" Text="—"
                           FontFamily="{StaticResource DisplayFont}" FontSize="40" FontWeight="Bold"
                           Foreground="#E6EDF3" Margin="0,-4,0,0"/>
              </StackPanel>
              <Canvas x:Name="WrChart" Grid.Column="1" Height="66" Margin="10,2,0,0"
                      ClipToBounds="True"/>
            </Grid>

            <!-- Фаза, в которой находится окно — крупно, снизу -->
            <TextBlock x:Name="ReadyStatusText" Text="Готов"
                       FontFamily="{StaticResource DisplayFont}" FontSize="21" FontWeight="Bold"
                       Foreground="#C89B3C" HorizontalAlignment="Center" TextAlignment="Center"
                       TextWrapping="Wrap" Margin="0,18,0,0"/>

            <!-- Карусель советов: поле фиксированного размера, смена раз в 40 с -->
            <Border Margin="0,15,0,0" Width="282" Height="118" CornerRadius="7"
                    Background="#14FFFFFF" BorderBrush="#33C89B3C" BorderThickness="1"
                    Padding="13,10">
              <StackPanel>
                <TextBlock Text="{loc:T ready.tipLabel}" FontFamily="{StaticResource UiFont}"
                           FontSize="10" FontWeight="Bold" Foreground="#C89B3C"
                           Opacity="0.8" Margin="0,0,0,6"/>
                <TextBlock x:Name="TipText" FontFamily="{StaticResource UiFont}" FontSize="12"
                           Foreground="#D7DEE6" TextWrapping="Wrap" LineHeight="16"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </StackPanel>

        <!-- ══ КОМПАКТНЫЙ ВИД ════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" x:Name="CompactScroll" Visibility="Collapsed"
                      VerticalScrollBarVisibility="Hidden" Margin="12,0,12,8">
          <ItemsControl x:Name="RecList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,3" Padding="8,7" CornerRadius="4" Background="#28C89B3C">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="22"/>
                      <ColumnDefinition Width="46"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="52"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Rank}" Foreground="#C89B3C"
                               FontFamily="{StaticResource UiFont}" FontSize="14" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Ellipse Grid.Column="1" Width="36" Height="36"
                             Margin="0,0,8,0" VerticalAlignment="Center">
                      <Ellipse.Fill>
                        <ImageBrush ImageSource="{Binding Icon}" Stretch="UniformToFill"/>
                      </Ellipse.Fill>
                      <Ellipse.Stroke><SolidColorBrush Color="#C89B3C"/></Ellipse.Stroke>
                      <Ellipse.StrokeThickness>1.5</Ellipse.StrokeThickness>
                    </Ellipse>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Name}" Foreground="White"
                                 FontFamily="{StaticResource UiFont}"
                                 FontSize="14" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding Reason}" Foreground="#5A7A90"
                                 FontFamily="{StaticResource UiFont}" FontSize="10.5"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock Grid.Column="3" Text="{Binding Score}"
                               Foreground="{Binding ScoreColor}"
                               FontFamily="{StaticResource UiFont}" FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <!-- ══ ПОЛНЫЙ ВИД ════════════════════════════════════════════ -->
        <Grid Grid.Row="2" x:Name="FullView" Visibility="Collapsed" Margin="12,0,12,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="282"/>  <!-- Моя команда — статичная ширина пиков -->
            <ColumnDefinition Width="*"/>    <!-- Рекомендации — забирают остаток       -->
            <ColumnDefinition Width="282"/>  <!-- Враги — статичная ширина пиков         -->
          </Grid.ColumnDefinitions>

          <!-- МОЯ КОМАНДА ─────────────────────────────────────────── -->
          <DockPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock DockPanel.Dock="Top"
                       Text="{loc:T team.myTeam}"
                       FontFamily="{StaticResource DisplayFont}" FontSize="15" FontWeight="Bold"
                       Foreground="#C89B3C" Margin="0,0,0,2"/>
            <TextBlock DockPanel.Dock="Top" x:Name="MyTeamStyle" Text=""
                       FontFamily="{StaticResource UiFont}" FontSize="11" FontWeight="Bold"
                       Foreground="#8AA0B2" Margin="0,0,0,10"/>
            <ScrollViewer VerticalScrollBarVisibility="Hidden">
              <StackPanel>
              <Grid>
              <ItemsControl x:Name="MyTeamList">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border BorderBrush="#22FFFFFF" BorderThickness="0,0,0,1"
                            Padding="0,3,0,9" Margin="0,1">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="76"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <Grid Width="72" Height="72" VerticalAlignment="Top"
                            HorizontalAlignment="Left" Margin="0,2,0,2">
                        <Ellipse Opacity="{Binding Opacity}"
                                 StrokeThickness="{Binding BorderThickness}">
                          <Ellipse.Fill>
                            <ImageBrush ImageSource="{Binding Icon}" Stretch="UniformToFill"/>
                          </Ellipse.Fill>
                          <Ellipse.Stroke>
                            <SolidColorBrush Color="{Binding BorderColor}"/>
                          </Ellipse.Stroke>
                          <Ellipse.Style>
                            <Style TargetType="Ellipse">
                              <Style.Triggers>
                                <!-- Золотое свечение моего слота -->
                                <DataTrigger Binding="{Binding IsMe}" Value="True">
                                  <Setter Property="Effect">
                                    <Setter.Value>
                                      <DropShadowEffect Color="#F5D77A" BlurRadius="18"
                                                        ShadowDepth="0" Opacity="0.95"/>
                                    </Setter.Value>
                                  </Setter>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Ellipse.Style>
                        </Ellipse>
                        <!-- Иконка роли в пустом моём слоте -->
                        <Image Source="{Binding RoleIcon}" Width="34" Height="34"
                               Stretch="Uniform" Opacity="0.9"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding RoleIconVisibility}"/>
                        <!-- Значок архетипа (камень/ножницы/бумага) в левом верхнем углу -->
                        <Border Width="27" Height="27" CornerRadius="13"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                Margin="0,0,0,0" Visibility="{Binding ArchVisibility}"
                                ToolTip="{Binding ArchTip}">
                          <Border.Background><SolidColorBrush Color="{Binding ArchColor}"/></Border.Background>
                          <TextBlock Text="{Binding ArchGlyph}" FontFamily="Segoe UI Emoji"
                                     FontSize="14" Foreground="#10141A"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                      </Grid>
                      <StackPanel Grid.Column="1" Margin="34,4,0,3">
                        <!-- Роль: у врага — кнопка-чип с выпадающим списком ролей -->
                        <Border HorizontalAlignment="Left"
                                Tag="{Binding RoleCellId}" ToolTip="{Binding RoleTip}"
                                MouseLeftButtonDown="EnemyRole_Click">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Setter Property="CornerRadius" Value="4"/>
                              <Setter Property="BorderBrush" Value="#557089"/>
                              <Setter Property="BorderThickness" Value="1"/>
                              <Setter Property="Background" Value="#1AFFFFFF"/>
                              <Setter Property="Padding" Value="7,1,7,2"/>
                              <Setter Property="Cursor" Value="Hand"/>
                              <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                  <Setter Property="Background" Value="#33FFFFFF"/>
                                  <Setter Property="BorderBrush" Value="#F5D77A"/>
                                </Trigger>
                                <!-- Союзник (RoleCellId=-1): обычный текст без рамки/клика -->
                                <DataTrigger Binding="{Binding RoleCellId}" Value="-1">
                                  <Setter Property="BorderThickness" Value="0"/>
                                  <Setter Property="Background" Value="Transparent"/>
                                  <Setter Property="Padding" Value="0"/>
                                  <Setter Property="Cursor" Value="Arrow"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                          <TextBlock Text="{Binding Role}" Foreground="{Binding RoleColor}"
                                     FontFamily="{StaticResource DisplayFont}"
                                     FontSize="12" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="{Binding Name}" Foreground="{Binding NameColor}"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="20" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                        <StackPanel Visibility="{Binding SideVisibility}" Margin="0,5,0,0">
                          <TextBlock Text="{Binding SideLabel}" Foreground="#4A6880"
                                     FontFamily="{StaticResource UiFont}"
                                     FontSize="9" FontWeight="Bold" Margin="0,0,0,2"/>
                          <ItemsControl ItemsSource="{Binding SideIcons}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Width="24" Height="24" CornerRadius="12"
                                        ClipToBounds="True" Margin="0,0,4,0">
                                  <Image Source="{Binding}" Stretch="UniformToFill"/>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </StackPanel>
                    </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <Canvas x:Name="MyTeamLines" IsHitTestVisible="False"/>
              </Grid>

              <TextBlock x:Name="MyCombosHeader" Text="{loc:T team.combos}" Visibility="Collapsed"
                         FontFamily="{StaticResource UiFont}" FontSize="10" FontWeight="Bold"
                         Foreground="#C89B3C" Margin="0,14,0,0"/>
              <ItemsControl x:Name="MyTeamCombos"
                            ItemTemplate="{StaticResource ComboTemplate}"/>
              </StackPanel>
            </ScrollViewer>
          </DockPanel>

          <!-- РЕКОМЕНДАЦИИ ──────────────────────────────────────────── -->
          <Border Grid.Column="1"
                  BorderBrush="#30C89B3C" BorderThickness="1,0"
                  Padding="10,0">
            <Grid>
            <ScrollViewer x:Name="RecScroll" VerticalScrollBarVisibility="Hidden">
              <ItemsControl x:Name="FullRecList">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,3" CornerRadius="4" Padding="10,9"
                            Background="{Binding CardBg}"
                            BorderBrush="{Binding CardBorder}" BorderThickness="1.5">
                      <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="Auto"/>  <!-- Ранг + очки      -->
                              <ColumnDefinition Width="Auto"/>  <!-- Иконка           -->
                              <ColumnDefinition Width="Auto"/>  <!-- Имя/WR/описание  -->
                              <ColumnDefinition Width="*"/>     <!-- Распорка         -->
                              <ColumnDefinition Width="Auto"/>  <!-- Показатели       -->
                            </Grid.ColumnDefinitions>

                            <!-- Ранг (крупно, отдельный шрифт) + очки под ним -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center"
                                        HorizontalAlignment="Center" Margin="0,0,14,0" MinWidth="46">
                              <TextBlock Text="{Binding Rank}" Foreground="#C89B3C"
                                         FontFamily="{StaticResource NumberFont}"
                                         FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                              <TextBlock Text="{Binding Score}" Foreground="{Binding ScoreColor}"
                                         FontFamily="{StaticResource NumberFont}"
                                         FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Иконка + значок архетипа; под иконкой — полоски связок -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,14,0">
                              <Grid>
                                <Ellipse Width="64" Height="64">
                                  <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding Icon}" Stretch="UniformToFill"/>
                                  </Ellipse.Fill>
                                  <Ellipse.Stroke><SolidColorBrush Color="#C89B3C"/></Ellipse.Stroke>
                                  <Ellipse.StrokeThickness>2</Ellipse.StrokeThickness>
                                </Ellipse>
                                <Border Width="27" Height="27" CornerRadius="13"
                                        HorizontalAlignment="Left" VerticalAlignment="Top"
                                        Visibility="{Binding ArchVisibility}" ToolTip="{Binding ArchTip}">
                                  <Border.Background><SolidColorBrush Color="{Binding ArchColor}"/></Border.Background>
                                  <TextBlock Text="{Binding ArchGlyph}" FontFamily="Segoe UI Emoji"
                                             FontSize="14" Foreground="#10141A"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                              </Grid>
                              <!-- Полоски связок кандидата с союзниками — во всю ширину иконки -->
                              <ItemsControl ItemsSource="{Binding SynDashes}" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <Border Width="64" Height="4" CornerRadius="2" Margin="0,1,0,0">
                                      <Border.Background><SolidColorBrush Color="{Binding}"/></Border.Background>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>

                            <!-- Имя + WR + описание: фиксированная ширина, отдельный столбец -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                        Width="230" Margin="0,0,14,0">
                              <TextBlock Text="{Binding MineLabel}" Foreground="#36D6E7"
                                         FontFamily="{StaticResource UiFont}" FontSize="11"
                                         FontWeight="Bold" Visibility="{Binding MineVisibility}"
                                         Margin="0,0,0,2"/>
                              <TextBlock Text="{Binding Name}" Foreground="White"
                                         FontFamily="{StaticResource DisplayFont}"
                                         FontSize="21" FontWeight="Bold"
                                         TextTrimming="CharacterEllipsis"/>
                              <TextBlock Text="{Binding WinRate}" Foreground="#4A6880"
                                         FontFamily="{StaticResource UiFont}" FontSize="12"/>
                              <TextBlock Foreground="#8AA6BC"
                                         loc:ReasonInlines.Segments="{Binding ReasonSegs}"
                                         FontFamily="{StaticResource UiFont}" FontSize="12"
                                         TextWrapping="Wrap" Margin="0,7,0,0" LineHeight="18"/>

                              <!-- Итемы, которыми враг контрит состав -->
                              <StackPanel Margin="0,8,0,0" Visibility="{Binding CounterItemsVisibility}">
                                <TextBlock Text="{loc:T draft.counterItems}" Foreground="#7C97AC"
                                           FontFamily="{StaticResource UiFont}" FontSize="10"/>
                                <ItemsControl ItemsSource="{Binding CounterItems}" Margin="0,3,0,0">
                                  <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                  </ItemsControl.ItemsPanel>
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                      <Border CornerRadius="3" Margin="0,0,4,0"
                                              BorderBrush="#4A3A22" BorderThickness="1">
                                        <Image Source="{Binding}" Width="22" Height="22"/>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </StackPanel>

                            <!-- Показатели: справа, по центру бокса -->
                            <StackPanel Grid.Column="4" Width="210" VerticalAlignment="Center">
                              <StackPanel.Resources>
                                <!-- Золотой прямоугольник у сильнейшей метрики (лейбл + число + бар) -->
                                <Style x:Key="MetricBox" TargetType="Border">
                                  <Setter Property="CornerRadius" Value="4"/>
                                  <Setter Property="Padding" Value="6,3"/>
                                  <Setter Property="Margin" Value="0,0,0,5"/>
                                  <Setter Property="BorderThickness" Value="1"/>
                                  <Setter Property="BorderBrush" Value="Transparent"/>
                                </Style>
                                <Style x:Key="StrongBase" TargetType="Border" BasedOn="{StaticResource MetricBox}">
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding BaseStrong}" Value="True">
                                      <Setter Property="Background" Value="#33F0C64A"/>
                                      <Setter Property="BorderBrush" Value="#B0F0C64A"/>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                                <Style x:Key="StrongDirect" TargetType="Border" BasedOn="{StaticResource MetricBox}">
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding DirectStrong}" Value="True">
                                      <Setter Property="Background" Value="#33F0C64A"/>
                                      <Setter Property="BorderBrush" Value="#B0F0C64A"/>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                                <Style x:Key="StrongOther" TargetType="Border" BasedOn="{StaticResource MetricBox}">
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding OtherStrong}" Value="True">
                                      <Setter Property="Background" Value="#33F0C64A"/>
                                      <Setter Property="BorderBrush" Value="#B0F0C64A"/>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                                <Style x:Key="StrongSyn" TargetType="Border" BasedOn="{StaticResource MetricBox}">
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding SynStrong}" Value="True">
                                      <Setter Property="Background" Value="#33F0C64A"/>
                                      <Setter Property="BorderBrush" Value="#B0F0C64A"/>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </StackPanel.Resources>

                              <!-- Винрейт в патче -->
                              <Border Style="{StaticResource StrongBase}">
                                <StackPanel>
                                  <Grid>
                                    <TextBlock Text="{loc:T metric.base}" Foreground="#7C97AC"
                                               FontFamily="{StaticResource UiFont}" FontSize="11"/>
                                    <TextBlock Text="{Binding BaseText}" Foreground="{Binding BaseColor}"
                                               FontFamily="{StaticResource UiFont}" FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Right"/>
                                  </Grid>
                                  <Grid Height="6" Margin="0,3,0,0">
                                    <Border Background="#1AFFFFFF" CornerRadius="3"/>
                                    <Border HorizontalAlignment="Left" Width="{Binding BaseBar}"
                                            Background="#4080C0" CornerRadius="3"/>
                                  </Grid>
                                </StackPanel>
                              </Border>

                              <!-- Против оппонента -->
                              <Border Style="{StaticResource StrongDirect}">
                                <StackPanel>
                                  <Grid>
                                    <TextBlock Text="{loc:T metric.direct}" Foreground="#7C97AC"
                                               FontFamily="{StaticResource UiFont}" FontSize="11"/>
                                    <TextBlock Text="{Binding DirectText}" Foreground="{Binding DirectColor}"
                                               FontFamily="{StaticResource UiFont}" FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Right"/>
                                  </Grid>
                                  <Grid Height="6" Margin="0,3,0,0">
                                    <Border Background="#1AFFFFFF" CornerRadius="3"/>
                                    <Border HorizontalAlignment="Left" Width="{Binding DirectBar}"
                                            Background="#C84040" CornerRadius="3"/>
                                  </Grid>
                                </StackPanel>
                              </Border>

                              <!-- Против вражеской команды -->
                              <Border Style="{StaticResource StrongOther}">
                                <StackPanel>
                                  <Grid>
                                    <TextBlock Text="{loc:T metric.style}" Foreground="#7C97AC"
                                               FontFamily="{StaticResource UiFont}" FontSize="11"/>
                                    <TextBlock Text="{Binding OtherText}" Foreground="{Binding OtherColor}"
                                               FontFamily="{StaticResource UiFont}" FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Right"/>
                                  </Grid>
                                  <Grid Height="6" Margin="0,3,0,0">
                                    <Border Background="#1AFFFFFF" CornerRadius="3"/>
                                    <Border HorizontalAlignment="Left" Width="{Binding OtherBar}"
                                            Background="#C87030" CornerRadius="3"/>
                                  </Grid>
                                </StackPanel>
                              </Border>

                              <!-- Синергия с союзниками -->
                              <Border Style="{StaticResource StrongSyn}">
                                <StackPanel>
                                  <Grid>
                                    <TextBlock Text="{loc:T metric.synergy}" Foreground="#7C97AC"
                                               FontFamily="{StaticResource UiFont}" FontSize="11"/>
                                    <TextBlock Text="{Binding SynText}" Foreground="{Binding SynColor}"
                                               FontFamily="{StaticResource UiFont}" FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Right"/>
                                  </Grid>
                                  <Grid Height="6" Margin="0,3,0,0">
                                    <Border Background="#1AFFFFFF" CornerRadius="3"/>
                                    <Border HorizontalAlignment="Left" Width="{Binding SynBar}"
                                            Background="#40A060" CornerRadius="3"/>
                                  </Grid>
                                </StackPanel>
                              </Border>
                            </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <!-- Список банов (фаза банов) — в том же центре, переключается с пиками -->
            <ScrollViewer x:Name="BanScroll" VerticalScrollBarVisibility="Hidden" Visibility="Collapsed">
              <ItemsControl x:Name="BanFullList">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,3" CornerRadius="4" Padding="12,10" Background="#1EC84040">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Rank}"
                                   FontFamily="{StaticResource NumberFont}" FontSize="30" FontWeight="Bold"
                                   Foreground="#E0584F" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Ellipse Grid.Column="1" Width="56" Height="56" VerticalAlignment="Center" Margin="0,0,12,0">
                          <Ellipse.Fill><ImageBrush ImageSource="{Binding Icon}" Stretch="UniformToFill"/></Ellipse.Fill>
                          <Ellipse.Stroke><SolidColorBrush Color="#C84040"/></Ellipse.Stroke>
                          <Ellipse.StrokeThickness>2</Ellipse.StrokeThickness>
                        </Ellipse>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name}" Foreground="White"
                                     FontFamily="{StaticResource DisplayFont}" FontSize="19" FontWeight="Bold"/>
                          <TextBlock Text="{Binding Reason}" Foreground="#9AB2C6"
                                     FontFamily="{StaticResource UiFont}" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" Text="{loc:T draft.banBadge}" Foreground="#E0584F"
                                   FontFamily="{StaticResource DisplayFont}" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
            </Grid>
          </Border>

          <!-- ВРАГИ ────────────────────────────────────────────────── -->
          <DockPanel Grid.Column="2" Margin="10,0,0,0">
            <TextBlock DockPanel.Dock="Top"
                       Text="{loc:T team.enemies}"
                       FontFamily="{StaticResource DisplayFont}" FontSize="15" FontWeight="Bold"
                       Foreground="#C84040" Margin="0,0,0,2"/>
            <TextBlock DockPanel.Dock="Top" x:Name="EnemyTeamStyle" Text=""
                       FontFamily="{StaticResource UiFont}" FontSize="11" FontWeight="Bold"
                       Foreground="#C08080" Margin="0,0,0,10"/>
            <ScrollViewer VerticalScrollBarVisibility="Hidden">
              <StackPanel>
              <Grid>
              <ItemsControl x:Name="EnemyTeamList">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border BorderBrush="#22FFFFFF" BorderThickness="0,0,0,1"
                            Padding="0,3,0,9" Margin="0,1">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="76"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <Grid Width="72" Height="72" VerticalAlignment="Top"
                            HorizontalAlignment="Left" Margin="0,2,0,2">
                        <Ellipse Opacity="{Binding Opacity}"
                                 StrokeThickness="{Binding BorderThickness}">
                          <Ellipse.Fill>
                            <ImageBrush ImageSource="{Binding Icon}" Stretch="UniformToFill"/>
                          </Ellipse.Fill>
                          <Ellipse.Stroke>
                            <SolidColorBrush Color="{Binding BorderColor}"/>
                          </Ellipse.Stroke>
                          <Ellipse.Style>
                            <Style TargetType="Ellipse">
                              <Style.Triggers>
                                <!-- Золотое свечение моего слота -->
                                <DataTrigger Binding="{Binding IsMe}" Value="True">
                                  <Setter Property="Effect">
                                    <Setter.Value>
                                      <DropShadowEffect Color="#F5D77A" BlurRadius="18"
                                                        ShadowDepth="0" Opacity="0.95"/>
                                    </Setter.Value>
                                  </Setter>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Ellipse.Style>
                        </Ellipse>
                        <!-- Иконка роли в пустом моём слоте -->
                        <Image Source="{Binding RoleIcon}" Width="34" Height="34"
                               Stretch="Uniform" Opacity="0.9"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding RoleIconVisibility}"/>
                        <!-- Значок архетипа (камень/ножницы/бумага) в левом верхнем углу -->
                        <Border Width="27" Height="27" CornerRadius="13"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                Margin="0,0,0,0" Visibility="{Binding ArchVisibility}"
                                ToolTip="{Binding ArchTip}">
                          <Border.Background><SolidColorBrush Color="{Binding ArchColor}"/></Border.Background>
                          <TextBlock Text="{Binding ArchGlyph}" FontFamily="Segoe UI Emoji"
                                     FontSize="14" Foreground="#10141A"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                      </Grid>
                      <StackPanel Grid.Column="1" Margin="34,4,0,3">
                        <!-- Роль: у врага — кнопка-чип с выпадающим списком ролей -->
                        <Border HorizontalAlignment="Left"
                                Tag="{Binding RoleCellId}" ToolTip="{Binding RoleTip}"
                                MouseLeftButtonDown="EnemyRole_Click">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Setter Property="CornerRadius" Value="4"/>
                              <Setter Property="BorderBrush" Value="#557089"/>
                              <Setter Property="BorderThickness" Value="1"/>
                              <Setter Property="Background" Value="#1AFFFFFF"/>
                              <Setter Property="Padding" Value="7,1,7,2"/>
                              <Setter Property="Cursor" Value="Hand"/>
                              <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                  <Setter Property="Background" Value="#33FFFFFF"/>
                                  <Setter Property="BorderBrush" Value="#F5D77A"/>
                                </Trigger>
                                <!-- Союзник (RoleCellId=-1): обычный текст без рамки/клика -->
                                <DataTrigger Binding="{Binding RoleCellId}" Value="-1">
                                  <Setter Property="BorderThickness" Value="0"/>
                                  <Setter Property="Background" Value="Transparent"/>
                                  <Setter Property="Padding" Value="0"/>
                                  <Setter Property="Cursor" Value="Arrow"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                          <TextBlock Text="{Binding Role}" Foreground="{Binding RoleColor}"
                                     FontFamily="{StaticResource DisplayFont}"
                                     FontSize="12" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="{Binding Name}" Foreground="{Binding NameColor}"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="20" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                        <StackPanel Visibility="{Binding SideVisibility}" Margin="0,5,0,0">
                          <TextBlock Text="{Binding SideLabel}" Foreground="#4A6880"
                                     FontFamily="{StaticResource UiFont}"
                                     FontSize="9" FontWeight="Bold" Margin="0,0,0,2"/>
                          <ItemsControl ItemsSource="{Binding SideIcons}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Width="24" Height="24" CornerRadius="12"
                                        ClipToBounds="True" Margin="0,0,4,0">
                                  <Image Source="{Binding}" Stretch="UniformToFill"/>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </StackPanel>
                    </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <Canvas x:Name="EnemyTeamLines" IsHitTestVisible="False"/>
              </Grid>

              <TextBlock x:Name="EnemyCombosHeader" Text="{loc:T team.enemyCombos}" Visibility="Collapsed"
                         FontFamily="{StaticResource UiFont}" FontSize="10" FontWeight="Bold"
                         Foreground="#C84040" Margin="0,14,0,0"/>
              <ItemsControl x:Name="EnemyTeamCombos"
                            ItemTemplate="{StaticResource ComboTemplate}"/>
              </StackPanel>
            </ScrollViewer>
          </DockPanel>
        </Grid>

        <!-- ── Дисклеймер (полный обязательный текст Riot) ───────────── -->
        <TextBlock Grid.Row="3"
                   Text="Counterplay isn't endorsed by Riot Games and doesn't reflect the views or opinions of Riot Games or anyone officially involved in producing or managing Riot Games properties. Riot Games, and all associated properties are trademarks or registered trademarks of Riot Games, Inc."
                   Foreground="#33708090" FontFamily="{StaticResource UiFont}" FontSize="9"
                   TextWrapping="Wrap" TextAlignment="Center"
                   HorizontalAlignment="Stretch" Margin="16,6,16,8"/>
      </Grid>
    </Border>

    <!-- ═══ RESIZE HANDLES — 8 направлений ═══════════════════════════ -->
    <!-- Края -->
    <Rectangle Height="6" VerticalAlignment="Top"    Fill="Transparent" Cursor="SizeNS"  MouseLeftButtonDown="ResN"/>
    <Rectangle Height="6" VerticalAlignment="Bottom" Fill="Transparent" Cursor="SizeNS"  MouseLeftButtonDown="ResS"/>
    <Rectangle Width="6"  HorizontalAlignment="Left"  Fill="Transparent" Cursor="SizeWE" MouseLeftButtonDown="ResW"/>
    <Rectangle Width="6"  HorizontalAlignment="Right" Fill="Transparent" Cursor="SizeWE" MouseLeftButtonDown="ResE"/>
    <!-- Углы -->
    <Rectangle Width="12" Height="12" HorizontalAlignment="Left"  VerticalAlignment="Top"    Fill="Transparent" Cursor="SizeNWSE" MouseLeftButtonDown="ResNW"/>
    <Rectangle Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Top"    Fill="Transparent" Cursor="SizeNESW" MouseLeftButtonDown="ResNE"/>
    <Rectangle Width="12" Height="12" HorizontalAlignment="Left"  VerticalAlignment="Bottom" Fill="Transparent" Cursor="SizeNESW" MouseLeftButtonDown="ResSW"/>
    <Rectangle Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="Transparent" Cursor="SizeNWSE" MouseLeftButtonDown="ResSE"/>

  </Grid>
</Window>
