# Коллектор статистики — скопируй в .env рядом и заполни.

# Публикация базы в GitHub release `data` после каждого круга сбора.
# Fine-grained токен: доступ только к репо counterplay, права Contents: read/write.
# Без токена коллектор просто собирает и не публикует.
GITHUB_TOKEN=
GITHUB_REPO=28maryshev/counterplay

# Уведомления: протух ключ / круг завершён / база опубликована.
# Discord → канал → Настройки → Интеграции → Вебхуки → создать → скопировать URL.
DISCORD_WEBHOOK=

# Что собирать. all = все регионы (параллельно) и все бакеты (сверху вниз).
# Регионы жмутся одновременно: у каждого хоста свой лимит Riot.
REGIONS=all
BUCKETS=all

# Окно матчей в днях.
COLLECT_DAYS=30
