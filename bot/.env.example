# Discord (портал разработчика: discord.com/developers)
DISCORD_TOKEN=
CLIENT_ID=              # application id
GUILD_ID=               # id сервера

# Каналы (Режим разработчика -> ПКМ по каналу -> «Копировать ID»).
# Пустое значение = функция выключена.
CH_META_RADAR=
CH_DRAFT_DUELS=
CH_SUBMIT_FINDS=        # форум-канал
CH_HALL_OF_FAME=

# Снапшот базы Counterplay (GitHub release с тегом data) — дефолты уже верные
DATA_DB_URL=https://github.com/28maryshev/counterplay/releases/download/data/data.db
DATA_VERSION_URL=https://github.com/28maryshev/counterplay/releases/download/data/data-version.json
DATA_DIR=./data
BOT_DB_PATH=./data/bot.db

ADMIN_USER_IDS=         # id админов через запятую
SITE_URL=https://counterplays.com
